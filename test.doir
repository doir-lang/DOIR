%32 : compiler.pointer_sized = 32
i32 : type = compiler.base_type(%32, %32)

add : (a: i32, b: i32) -> i32 = {
	%0 : compiler.byte = 0x64
	%1 : compiler.byte = compiler.emit(a)
	%2 : alias = a
	_ : i32 = compiler.indicate_return(i32)
}

a : i32
b : i32 <../test.doir:2:0>
x : i32 = 5
y : i32 = 6 <../test.doir:4:0>
export z : i32 = 7 <../test.doir:5:0>

%0 : i32 = inline add(a, b)

