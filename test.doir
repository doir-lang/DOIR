path : compiler.byte_pointer = "./mizu.doir" 
_ : compiler.byte = early_include(path)
_ : compiler.assembler.register = compiler.assembler.begin_register_allocation()

u64 : alias = mizu.u64

blk : block = {
	a : u64 = 1234
	_ : u64 = mizu.load_immediate(u64, a)
	_ : u64 = compiler.assembler.pin_register(u64, a, mizu.x1)
	_ : u64 = mizu.debug_print(a)
}
false : u64 = 0
true : u64 = 1
_ : u64 = mizu.doir_execute_if(blk, true)

a : u64 = 5
_ : u64 = mizu.load_immediate(u64, a)
b : u64 = 6
_ : u64 = mizu.load_immediate(u64, b)
c : u64 = mizu.add(a, b)
d : u64 = 7
_ : u64 = mizu.load_immediate(u64, d)
e : u64 = mizu.subtract(c, d)
f : u64 = mizu.debug_print(e)
_ : u64 = mizu.halt()
_ : u64 = mizu.halt()
_ : u64 = compiler.assembler.pin_register(u64, a, mizu.x1)
_ : u64 = compiler.assembler.pin_register(u64, b, mizu.x2)
_ : u64 = compiler.assembler.pin_register(u64, c, mizu.x3)
_ : u64 = compiler.assembler.pin_register(u64, d, mizu.x4)
_ : u64 = compiler.assembler.pin_register(u64, e, mizu.x5)
_ : u64 = compiler.assembler.pin_register(u64, f, mizu.x6)