a : i32
b : i32 <../test.doir:2:0>
x : i32 = 5
y : i32 = 6 <../test.doir:4:0>
export z : i32 = 7 <../test.doir:5:0>

return : (T: type, out: T) -> T

c : namespace = {
	base_type_t : type = (size_bits : pointer_sized, align_bits : pointer_sized) -> type
	base_type : base_type_t = {
		out : type = compiler.base_type(size_bits, align_bits)
		_ : _ = return(type, out)
	}
	%64 : pointer_sized = 64
	pointer_sized : type = base_type(%64, %64)
	%8 : pointer_sized = 8
	byte : type = base_type(%8, %8)

	emit : (out : byte) -> byte = {
		output : byte = compiler.emit(out)
		_ : _ = return(byte, output)
	}
}

%0 : compiler.byte = 0x64
%1 : compiler.byte = compiler.emit(%0)

